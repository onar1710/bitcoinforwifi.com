---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - BitcoinForWifi">
	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<!-- Hero Section -->
				<div class="text-center mb-16">
					<h1 class="text-4xl md:text-5xl font-bold mb-6">
						<span class="gradient-text">About BitcoinForWifi</span>
					</h1>
					<p class="text-xl text-gray-300 leading-relaxed">
						We are passionate experts in the world of cryptocurrencies, 
						dedicated to sharing knowledge and deep analysis about Bitcoin 
						and blockchain technology.
					</p>
				</div>
				
				<!-- Mission Section -->
				<div class="bg-dark-card border border-dark-border rounded-lg p-8 mb-12">
					<h2 class="text-3xl font-bold mb-6">Our Mission</h2>
					<p class="text-gray-300 text-lg leading-relaxed mb-6">
						At BitcoinForWifi, our mission is to democratize knowledge about 
						Bitcoin and cryptocurrencies. We believe everyone should have access 
						to clear, accurate, and reliable information about this financial revolution.
					</p>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
						<div class="text-center">
							<div class="w-16 h-16 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mx-auto mb-4">
								<svg class="w-8 h-8 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">Education</h3>
							<p class="text-gray-400 text-sm">Quality educational content for all levels</p>
						</div>
						<div class="text-center">
							<div class="w-16 h-16 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mx-auto mb-4">
								<svg class="w-8 h-8 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">Excellence</h3>
							<p class="text-gray-400 text-sm">Deep analysis and high-quality content</p>
						</div>
						<div class="text-center">
							<div class="w-16 h-16 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mx-auto mb-4">
								<svg class="w-8 h-8 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 16c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">Accessibility</h3>
							<p class="text-gray-400 text-sm">Making cryptocurrencies understandable for everyone</p>
						</div>
					</div>
				</div>
				
				<!-- About Bitcoin -->
				<div class="mb-12">
					<h2 class="text-3xl font-bold mb-6">Why Bitcoin?</h2>
					<p class="text-gray-300 text-lg leading-relaxed mb-6">
						Bitcoin is not just a cryptocurrency, it's a revolutionary technology that is 
						changing the way we understand money, transactions and trust 
						in digital systems.
					</p>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<div>
							<h3 class="text-xl font-semibold mb-4 text-bitcoin-orange">Innovative Technology</h3>
							<p class="text-gray-400">
								Bitcoin's blockchain represents a technological advance comparable to the invention 
								of the internet. Its ability to create decentralized consensus opens infinite possibilities.
							</p>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-4 text-bitcoin-orange">Financial Inclusion</h3>
							<p class="text-gray-400">
								Bitcoin offers access to financial services to billions of people who are currently 
								excluded from the traditional banking system.
							</p>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-4 text-bitcoin-orange">Asset Protection</h3>
							<p class="text-gray-400">
								In a world of growing inflation, Bitcoin offers an alternative to protect 
								the value of money in the long term with its limited supply.
							</p>
						</div>
						<div>
							<h3 class="text-xl font-semibold mb-4 text-bitcoin-orange">Individual Sovereignty</h3>
							<p class="text-gray-400">
								Bitcoin gives you complete control over your funds, without depending on third parties or intermediaries 
								that can block or confiscate your assets.
							</p>
						</div>
					</div>
				</div>
				
				<!-- Team Section -->
				<div class="mb-12">
					<h2 class="text-3xl font-bold mb-8">Our Team</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
						<div class="bg-dark-card border border-dark-border rounded-lg p-6 text-center">
							<div class="w-20 h-20 bg-bitcoin-orange/20 rounded-full flex items-center justify-center mx-auto mb-4">
								<svg class="w-10 h-10 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">Michael Anderson</h3>
							<p class="text-gray-400 text-sm mb-2">Founder & Editor in Chief</p>
							<p class="text-gray-500 text-xs">Blockchain expert with 8+ years of experience</p>
						</div>
						<div class="bg-dark-card border border-dark-border rounded-lg p-6 text-center">
							<div class="w-20 h-20 bg-bitcoin-orange/20 rounded-full flex items-center justify-center mx-auto mb-4">
								<svg class="w-10 h-10 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">Sarah Johnson</h3>
							<p class="text-gray-400 text-sm mb-2">Technical Analyst</p>
							<p class="text-gray-500 text-xs">Specialist in trading and market analysis</p>
						</div>
						<div class="bg-dark-card border border-dark-border rounded-lg p-6 text-center">
							<div class="w-20 h-20 bg-bitcoin-orange/20 rounded-full flex items-center justify-center mx-auto mb-4">
								<svg class="w-10 h-10 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
								</svg>
							</div>
							<h3 class="font-semibold mb-2">David Thompson</h3>
							<p class="text-gray-400 text-sm mb-2">Blockchain Developer</p>
							<p class="text-gray-500 text-xs">Expert in smart contracts and DeFi</p>
						</div>
					</div>
				</div>
				
				<!-- Stats Section -->
				<div class="bg-gradient-to-r from-bitcoin-orange/20 to-transparent rounded-lg p-8 mb-12">
					<h2 class="text-3xl font-bold mb-8 text-center">Our Impact</h2>
					<div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
						<div>
							<div class="text-3xl font-bold text-bitcoin-orange mb-2">150+</div>
							<div class="text-gray-400">Published Articles</div>
						</div>
						<div>
							<div class="text-3xl font-bold text-bitcoin-orange mb-2">50K+</div>
							<div class="text-gray-400">Monthly Readers</div>
						</div>
						<div>
							<div class="text-3xl font-bold text-bitcoin-orange mb-2">1000+</div>
							<div class="text-gray-400">Newsletter Subscribers</div>
						</div>
						<div>
							<div class="text-3xl font-bold text-bitcoin-orange mb-2">4.9</div>
							<div class="text-gray-400">Average Rating</div>
						</div>
					</div>
				</div>
				
				<!-- CTA Section -->
				<div class="text-center">
					<h2 class="text-3xl font-bold mb-6">
						<span class="gradient-text">Join the Community</span>
					</h2>
					<p class="text-gray-300 text-lg mb-8">
						Want to learn more about Bitcoin and cryptocurrencies? 
						Explore our articles or subscribe to our newsletter.
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="/blog" class="px-8 py-3 bg-bitcoin-orange text-white font-semibold rounded-lg hover:bg-bitcoin-light transition-colors">
							Explore Blog
						</a>
						<a href="#newsletter" class="px-8 py-3 border-2 border-bitcoin-orange text-bitcoin-orange font-semibold rounded-lg hover:bg-bitcoin-orange hover:text-white transition-colors">
							Subscribe
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
