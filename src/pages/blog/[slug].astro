---
import Layout from '../../layouts/Layout.astro';
import { getPostBySlug, getPublishedPosts } from '../../data/blog-posts.js';
import { processInternalLinks, generateRelatedArticlesSection } from '../../utils/internalLinking.js';

export const PAGINATION = {
  postsPerPage: 6
};

export async function getStaticPaths() {
  const posts = getPublishedPosts();
  
  return posts.map(post => ({
    params: { slug: post.slug },
    props: post
  }));
}

const post = Astro.props;
const processedContent = processInternalLinks(post);
const relatedArticles = generateRelatedArticlesSection(post, 3);
---

<Layout title={post.title}>
	<article class="py-20">
		<div class="container mx-auto px-4 max-w-4xl">
			<!-- Header -->
			<header class="mb-12">
				<div class="flex items-center space-x-2 text-sm text-gray-400 mb-4">
					<span class="px-3 py-1 bg-bitcoin-orange text-white text-xs font-semibold rounded-full">
						{post.category}
					</span>
					<time datetime={post.date}>
						{new Date(post.date).toLocaleDateString('en-US', { 
							year: 'numeric', 
							month: 'long', 
							day: 'numeric' 
						})}
					</time>
					<span>•</span>
					<span>{post.readTime}</span>
				</div>
				
				<h1 class="text-4xl md:text-5xl font-bold mb-6">
					<span class="gradient-text">{post.title}</span>
				</h1>
				
				<p class="text-xl text-gray-300 mb-8">{post.description}</p>
				
				<!-- Author Info -->
				<div class="flex items-center space-x-4 p-4 bg-dark-card border border-dark-border rounded-lg">
					<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-full flex items-center justify-center">
						<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
						</svg>
					</div>
					<div>
						<div class="font-semibold">{post.author}</div>
						<div class="text-sm text-gray-400">Expert Bitcoin Analyst</div>
					</div>
				</div>
			</header>
			
			<!-- Content with Internal Links -->
			<div class="prose prose-lg prose-invert max-w-none">
				<Fragment set:html={processedContent.content} />
			</div>
			
			<!-- Internal Links Summary -->
			{processedContent.internalLinks.length > 0 && (
				<div class="mt-12 p-6 bg-dark-card border border-dark-border rounded-lg">
					<h3 class="text-lg font-semibold mb-4">Enlaces Internos en este Artículo</h3>
					<div class="space-y-2">
						{processedContent.internalLinks.map(link => (
							<div class="flex items-center space-x-2">
								<svg class="w-4 h-4 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
									<path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
								</svg>
								<a href={link.url} class="text-bitcoin-orange hover:text-bitcoin-light transition-colors">
									{link.anchorText}
								</a>
								<span class="text-gray-500 text-sm">→ {link.title}</span>
							</div>
						))}
					</div>
				</div>
			)}
			
			<!-- Tags -->
			<div class="mt-12 pt-8 border-t border-dark-border">
				<h3 class="text-lg font-semibold mb-4">Tags</h3>
				<div class="flex flex-wrap gap-2">
					{post.tags.map(tag => (
						<span class="px-3 py-1 bg-dark border border-dark-border text-gray-300 text-sm rounded-full hover:border-bitcoin-orange hover:text-bitcoin-orange transition-colors cursor-pointer">
							{tag}
						</span>
					))}
				</div>
			</div>
			
			<!-- Share Buttons -->
			<div class="mt-12 pt-8 border-t border-dark-border">
				<h3 class="text-lg font-semibold mb-4">Share</h3>
				<div class="flex space-x-4">
					<button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
						Share on Twitter
					</button>
					<button class="px-4 py-2 bg-blue-800 text-white rounded-lg hover:bg-blue-900 transition-colors">
						Share on Facebook
					</button>
					<button class="px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-800 transition-colors">
						Copy Link
					</button>
				</div>
			</div>
			
			<!-- Related Posts -->
			<div class="mt-16 pt-8 border-t border-dark-border">
				<h3 class="text-2xl font-bold mb-8">
					<span class="gradient-text">Related Articles</span>
				</h3>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{relatedArticles.map(relatedPost => (
						<article class="bg-dark-card border border-dark-border rounded-lg p-6 card-hover">
							<h4 class="text-lg font-semibold mb-3 hover:text-bitcoin-orange transition-colors">
								<a href={`/blog/${relatedPost.slug}`}>{relatedPost.title}</a>
							</h4>
							<p class="text-gray-400 mb-3">{relatedPost.description}</p>
							<div class="text-sm text-gray-500">{relatedPost.readTime}</div>
						</article>
					))}
				</div>
			</div>
		</div>
	</article>
</Layout>
