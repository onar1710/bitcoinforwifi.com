---
import { blogPosts } from '../../data/blog-posts.js';

export const PAGINATION = {
  postsPerPage: 6
};

export async function getStaticPaths() {
  const posts = blogPosts
    .filter(post => post.published)
    .map(post => ({
      slug: post.slug,
      title: post.title,
      description: post.description,
      date: post.date,
      readTime: post.readTime,
      category: post.category,
      author: post.author,
      content: post.content
    }));

  return posts.map(post => ({
    params: { slug: post.slug },
    props: post
  }));
}

const { title, description, date, readTime, category, author, content } = Astro.props;
const SITE_URL = 'https://bitcoinforwifi.com';
const articleUrl = `${SITE_URL}/blog/${Astro.params.slug}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- AMP Boilerplate -->
    <style amp-boilerplate>body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}</style>
    <noscript><style amp-boilerplate>body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}</style></noscript>
    
    <!-- AMP Runtime -->
    <script async src="https://cdn.ampproject.org/v0.js" is:inline></script>
    
    <!-- AMP Components -->
    <script async custom-element="amp-social-share" src="https://cdn.ampproject.org/v0/amp-social-share-0.1.js" is:inline></script>
    <script async custom-element="amp-accordion" src="https://cdn.ampproject.org/v0/amp-accordion-0.1.js" is:inline></script>
    
    <!-- Canonical URL -->
    <link rel="canonical" href={articleUrl}>
    
    <!-- Schema.org -->
    <script type="application/ld+json" is:inline>
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {JSON.stringify(title)},
        "description": {JSON.stringify(description)},
        "image": "https://bitcoinforwifi.com/og-image.jpg",
        "author": {
            "@type": "Person",
            "name": {JSON.stringify(author)}
        },
        "publisher": {
            "@type": "Organization",
            "name": "BitcoinForWifi",
            "logo": {
                "@type": "ImageObject",
                "url": "https://bitcoinforwifi.com/logo.svg",
                "width": 512,
                "height": 512
            }
        },
        "datePublished": {JSON.stringify(date)},
        "dateModified": {JSON.stringify(date)},
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": {JSON.stringify(articleUrl)}
        }
    }
    </script>
    
    <style amp-custom>
        * {
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
            background: #fff;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .article-header {
            padding: 40px 0;
            text-align: center;
            background: linear-gradient(135deg, #f7931a 0%, #ffad33 100%);
            color: white;
            margin-bottom: 40px;
        }
        
        .article-header h1 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            font-weight: bold;
            line-height: 1.2;
        }
        
        .article-header p {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto 20px;
        }
        
        .article-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }
        
        .category-badge {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 0.8rem;
            font-weight: bold;
        }
        
        .meta-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.9rem;
            opacity: 0.9;
        }
        
        .author-section {
            background: #f8f9fa;
            padding: 30px;
            border-radius: 10px;
            margin: 40px 0;
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .author-avatar {
            width: 60px;
            height: 60px;
            background: #f7931a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .author-avatar svg {
            width: 30px;
            height: 30px;
            fill: white;
        }
        
        .author-info h3 {
            margin: 0 0 5px 0;
            font-size: 1.1rem;
            color: #333;
        }
        
        .author-info p {
            margin: 0;
            color: #666;
            font-size: 0.9rem;
        }
        
        .article-content {
            margin: 40px 0;
        }
        
        .article-content h1 {
            font-size: 2rem;
            margin: 40px 0 20px 0;
            color: #333;
        }
        
        .article-content h2 {
            font-size: 1.5rem;
            margin: 30px 0 15px 0;
            color: #333;
        }
        
        .article-content h3 {
            font-size: 1.2rem;
            margin: 25px 0 10px 0;
            color: #333;
        }
        
        .article-content p {
            margin: 20px 0;
            color: #666;
            line-height: 1.8;
        }
        
        .article-content ul,
        .article-content ol {
            margin: 20px 0;
            padding-left: 30px;
            color: #666;
        }
        
        .article-content li {
            margin: 10px 0;
            line-height: 1.6;
        }
        
        .article-content strong {
            color: #333;
            font-weight: 600;
        }
        
        .article-content em {
            font-style: italic;
            color: #666;
        }
        
        .article-content a {
            color: #f7931a;
            text-decoration: none;
        }
        
        .article-content a:hover {
            text-decoration: underline;
        }
        
        .article-content blockquote {
            background: #f8f9fa;
            border-left: 4px solid #f7931a;
            padding: 20px;
            margin: 30px 0;
            font-style: italic;
            color: #666;
        }
        
        .article-content hr {
            border: none;
            height: 1px;
            background: #e9ecef;
            margin: 40px 0;
        }
        
        .tags-section {
            margin: 40px 0;
            padding: 30px 0;
            border-top: 1px solid #e9ecef;
            border-bottom: 1px solid #e9ecef;
        }
        
        .tags-title {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #333;
        }
        
        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .tag {
            background: #f8f9fa;
            color: #666;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            border: 1px solid #e9ecef;
            transition: all 0.3s;
        }
        
        .tag:hover {
            background: #f7931a;
            color: white;
            border-color: #f7931a;
        }
        
        .share-section {
            margin: 40px 0;
            padding: 30px 0;
            border-bottom: 1px solid #e9ecef;
        }
        
        .share-title {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #333;
        }
        
        .share-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        .related-section {
            margin: 40px 0;
            padding: 40px 0;
            border-top: 1px solid #e9ecef;
        }
        
        .related-title {
            font-size: 1.5rem;
            margin-bottom: 25px;
            color: #333;
        }
        
        .related-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .related-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 25px;
            transition: transform 0.3s;
        }
        
        .related-card:hover {
            transform: translateY(-5px);
        }
        
        .related-card h3 {
            margin: 0 0 10px 0;
            color: #333;
        }
        
        .related-card h3 a {
            color: #333;
            text-decoration: none;
        }
        
        .related-card h3 a:hover {
            color: #f7931a;
        }
        
        .related-card p {
            margin: 0 0 10px 0;
            color: #666;
            font-size: 0.9rem;
        }
        
        .related-card .read-time {
            color: #999;
            font-size: 0.8rem;
        }
        
        .footer {
            background: #333;
            color: white;
            padding: 40px 0;
            text-align: center;
            margin-top: 60px;
        }
        
        @media (max-width: 768px) {
            .article-header h1 {
                font-size: 2rem;
            }
            
            .article-header p {
                font-size: 1rem;
            }
            
            .article-meta {
                flex-direction: column;
                gap: 10px;
            }
            
            .author-section {
                flex-direction: column;
                text-align: center;
            }
            
            .article-content h1 {
                font-size: 1.5rem;
            }
            
            .article-content h2 {
                font-size: 1.3rem;
            }
            
            .related-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="article-header">
        <div class="container">
            <div class="article-meta">
                <span class="category-badge">{category}</span>
                <span class="meta-item">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
                    </svg>
                    {new Date(date).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    })}
                </span>
                <span class="meta-item">•</span>
                <span class="meta-item">{readTime}</span>
            </div>
            
            <h1>{title}</h1>
            <p>{description}</p>
        </div>
    </header>

    <main class="container">
        <!-- Author Section -->
        <div class="author-section">
            <div class="author-avatar">
                <svg viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </div>
            <div class="author-info">
                <h3>{author}</h3>
                <p>Expert Bitcoin Analyst</p>
            </div>
        </div>
        
        <!-- Article Content -->
        <article class="article-content">
            <Fragment set:html={content} />
        </article>
        
        <!-- Tags Section -->
        <section class="tags-section">
            <h2 class="tags-title">Tags</h2>
            <div class="tags">
                <span class="tag">Bitcoin</span>
                <span class="tag">Beginners</span>
                <span class="tag">Guide</span>
                <span class="tag">Cryptocurrencies</span>
            </div>
        </section>
        
        <!-- Share Section -->
        <section class="share-section">
            <h2 class="share-title">Share this article</h2>
            <div class="share-buttons">
                <amp-social-share type="twitter" width="45" height="33"></amp-social-share>
                <amp-social-share type="facebook" width="45" height="33"></amp-social-share>
                <amp-social-share type="linkedin" width="45" height="33"></amp-social-share>
                <amp-social-share type="email" width="45" height="33"></amp-social-share>
            </div>
        </section>
        
        <!-- Related Articles -->
        <section class="related-section">
            <h2 class="related-title">Related Articles</h2>
            <div class="related-grid">
                <article class="related-card">
                    <h3><a href="/blog/blockchain-explained">Blockchain Explained for Humans</a></h3>
                    <p>Understand the technology behind Bitcoin in a simple and clear way.</p>
                    <div class="read-time">8 min read</div>
                </article>
                
                <article class="related-card">
                    <h3><a href="/blog/bitcoin-wallets-security">Bitcoin Wallets: Security Guide</a></h3>
                    <p>Learn to protect your bitcoins with the best security practices.</p>
                    <div class="read-time">10 min read</div>
                </article>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 BitcoinForWifi. All rights reserved.</p>
            <p style="margin-top: 10px; font-size: 0.9rem; opacity: 0.8;">
                <a href="/privacy" style="color: #f7931a; text-decoration: none; margin: 0 10px;">Privacy</a> • 
                <a href="/terms" style="color: #f7931a; text-decoration: none; margin: 0 10px;">Terms</a> • 
                <a href="/disclaimer" style="color: #f7931a; text-decoration: none; margin: 0 10px;">Disclaimer</a>
            </p>
        </div>
    </footer>
</body>
</html>
