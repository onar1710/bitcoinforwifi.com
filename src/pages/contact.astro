---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - BitcoinForWifi">
	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto">
				<div class="text-center mb-16">
					<h1 class="text-4xl md:text-5xl font-bold mb-6">
						<span class="gradient-text">Get in Touch</span>
					</h1>
					<p class="text-xl text-gray-300 leading-relaxed">
						Have questions about Bitcoin or want to collaborate? We'd love to hear from you.
					</p>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
					<!-- Contact Form -->
					<div class="bg-dark-card border border-dark-border rounded-lg p-8">
						<h2 class="text-2xl font-bold mb-6">Send us a Message</h2>
						<form id="contact-form" class="space-y-6">
							<div>
								<label for="name" class="block text-sm font-medium text-gray-300 mb-2">
									Name *
								</label>
								<input
									type="text"
									id="name"
									name="name"
									required
									class="w-full px-4 py-3 bg-dark border border-dark-border rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-bitcoin-orange transition-colors"
									placeholder="John Doe"
								/>
							</div>

							<div>
								<label for="email" class="block text-sm font-medium text-gray-300 mb-2">
									Email *
								</label>
								<input
									type="email"
									id="email"
									name="email"
									required
									class="w-full px-4 py-3 bg-dark border border-dark-border rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-bitcoin-orange transition-colors"
									placeholder="john@example.com"
								/>
							</div>

							<div>
								<label for="subject" class="block text-sm font-medium text-gray-300 mb-2">
									Subject *
								</label>
								<select
									id="subject"
									name="subject"
									required
									class="w-full px-4 py-3 bg-dark border border-dark-border rounded-lg text-white focus:outline-none focus:border-bitcoin-orange transition-colors"
								>
									<option value="">Select a topic</option>
									<option value="general">General Inquiry</option>
									<option value="collaboration">Collaboration</option>
									<option value="technical">Technical Support</option>
									<option value="press">Press & Media</option>
									<option value="other">Other</option>
								</select>
							</div>

							<div>
								<label for="message" class="block text-sm font-medium text-gray-300 mb-2">
									Message *
								</label>
								<textarea
									id="message"
									name="message"
									rows="5"
									required
									class="w-full px-4 py-3 bg-dark border border-dark-border rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-bitcoin-orange transition-colors resize-none"
									placeholder="Tell us what's on your mind..."
								></textarea>
							</div>

							<div class="flex items-start">
								<input
									type="checkbox"
									id="newsletter"
									name="newsletter"
									class="mt-1 w-4 h-4 bg-dark border-dark-border rounded focus:ring-bitcoin-orange focus:border-bitcoin-orange"
								/>
								<label for="newsletter" class="ml-2 text-sm text-gray-300">
									I'd like to receive the BitcoinForWifi newsletter with latest updates and insights.
								</label>
							</div>

							<button
								type="submit"
								class="w-full px-6 py-3 bg-bitcoin-orange text-white font-semibold rounded-lg hover:bg-bitcoin-light transition-colors duration-300 transform hover:scale-105"
							>
								Send Message
							</button>
						</form>

						<div id="form-message" class="hidden mt-4 p-4 rounded-lg"></div>
					</div>

					<!-- Contact Information -->
					<div class="space-y-8">
						<div class="bg-dark-card border border-dark-border rounded-lg p-8">
							<h2 class="text-2xl font-bold mb-6">Contact Information</h2>
							
							<div class="space-y-6">
								<div class="flex items-start space-x-4">
									<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
											<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-lg mb-1">Office Address</h3>
										<p class="text-gray-400">
											123 Wall Street<br>
											New York, NY 10005<br>
											United States
										</p>
									</div>
								</div>

								<div class="flex items-start space-x-4">
									<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
											<path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-lg mb-1">Email</h3>
										<p class="text-gray-400">
											contact@bitcoinforwifi.com<br>
											support@bitcoinforwifi.com
										</p>
									</div>
								</div>

								<div class="flex items-start space-x-4">
									<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center flex-shrink-0">
										<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
											<path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-lg mb-1">Phone</h3>
										<p class="text-gray-400">
											+1 (555) 123-4567<br>
											Mon-Fri 9:00 AM - 6:00 PM EST
										</p>
									</div>
								</div>
							</div>
						</div>

						<!-- Social Media -->
						<div class="bg-dark-card border border-dark-border rounded-lg p-8">
							<h2 class="text-2xl font-bold mb-6">Connect With Us</h2>
							<p class="text-gray-400 mb-6">
								Follow us on social media for the latest Bitcoin insights and updates.
							</p>
							
							<div class="grid grid-cols-2 gap-4">
								<a href="#" class="flex items-center space-x-3 p-3 bg-dark border border-dark-border rounded-lg hover:border-bitcoin-orange transition-colors group">
									<svg class="w-5 h-5 text-gray-400 group-hover:text-bitcoin-orange transition-colors" fill="currentColor" viewBox="0 0 24 24">
										<path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
									</svg>
									<span class="text-gray-300 group-hover:text-white transition-colors">Twitter</span>
								</a>

								<a href="#" class="flex items-center space-x-3 p-3 bg-dark border border-dark-border rounded-lg hover:border-bitcoin-orange transition-colors group">
									<svg class="w-5 h-5 text-gray-400 group-hover:text-bitcoin-orange transition-colors" fill="currentColor" viewBox="0 0 24 24">
										<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>
									</svg>
									<span class="text-gray-300 group-hover:text-white transition-colors">GitHub</span>
								</a>

								<a href="#" class="flex items-center space-x-3 p-3 bg-dark border border-dark-border rounded-lg hover:border-bitcoin-orange transition-colors group">
									<svg class="w-5 h-5 text-gray-400 group-hover:text-bitcoin-orange transition-colors" fill="currentColor" viewBox="0 0 24 24">
										<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
										<circle cx="4" cy="4" r="2"/>
									</svg>
									<span class="text-gray-300 group-hover:text-white transition-colors">LinkedIn</span>
								</a>

								<a href="#" class="flex items-center space-x-3 p-3 bg-dark border border-dark-border rounded-lg hover:border-bitcoin-orange transition-colors group">
									<svg class="w-5 h-5 text-gray-400 group-hover:text-bitcoin-orange transition-colors" fill="currentColor" viewBox="0 0 24 24">
										<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 004.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
									</svg>
									<span class="text-gray-300 group-hover:text-white transition-colors">Discord</span>
								</a>
							</div>
						</div>

						<!-- FAQ Section -->
						<div class="bg-dark-card border border-dark-border rounded-lg p-8">
							<h2 class="text-2xl font-bold mb-6">Frequently Asked Questions</h2>
							
							<div class="space-y-4">
								<div class="border-b border-dark-border pb-4">
									<h3 class="font-semibold mb-2">How quickly do you respond to inquiries?</h3>
									<p class="text-gray-400 text-sm">
										We typically respond within 24-48 hours during business days. For urgent matters, please call us directly.
									</p>
								</div>

								<div class="border-b border-dark-border pb-4">
									<h3 class="font-semibold mb-2">Do you offer consulting services?</h3>
									<p class="text-gray-400 text-sm">
										Yes, we offer Bitcoin consulting services. Please select "Collaboration" as the subject and we'll get back to you with details.
									</p>
								</div>

								<div class="border-b border-dark-border pb-4">
									<h3 class="font-semibold mb-2">Can I contribute content to BitcoinForWifi?</h3>
									<p class="text-gray-400 text-sm">
										We're always looking for expert contributors! Send us a message with your background and writing samples.
									</p>
								</div>

								<div>
									<h3 class="font-semibold mb-2">Do you provide investment advice?</h3>
									<p class="text-gray-400 text-sm">
										No, we provide educational content only. For investment advice, please consult with a qualified financial advisor.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		function handleSubmit(e: Event) {
			e.preventDefault();
			const target = e.currentTarget as HTMLFormElement;
			const submitButton = target.querySelector('button[type="submit"]') as HTMLButtonElement;
			
			// Get form data
			const formData = new FormData(target);
			const name = formData.get('name') as string;
			const email = formData.get('email') as string;
			const message = formData.get('message') as string;
			
			// Basic validation
			if (!name || !email || !message) {
				alert('Please fill in all fields');
				return;
			}
			
			// Show loading state
			if (submitButton) {
				submitButton.disabled = true;
				submitButton.textContent = 'Sending...';
			}
			
			// Simulate form submission
			setTimeout(() => {
				alert('Thank you for your message! I\'ll get back to you soon.');
				target.reset();
				
				// Reset button state
				if (submitButton) {
					submitButton.disabled = false;
					submitButton.textContent = 'Send Message';
				}
			}, 1000);
		}

		document.getElementById('contact-form').addEventListener('submit', handleSubmit);
	</script>
</Layout>
