---
import Layout from '../layouts/Layout.astro';
import { blogPosts } from '../data/blog-posts';
import { formatDate } from '../utils/dateUtils.js';

const SITE = {
  title: 'Expert blog on Bitcoin and cryptocurrency investing - BitcoinForWifi',
  description: 'Expert blog about Bitcoin, blockchain technology and the future of decentralized finance',
  url: 'https://bitcoinforwifi.com'
};

const latestPosts = blogPosts.filter(post => post.published).slice(0, 6);
---

<Layout title={SITE.title}>
	<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-bitcoin-orange/20 to-transparent"></div>
		<div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
		
		<div class="relative z-10 container mx-auto px-4 text-center">
			<div class="max-w-4xl mx-auto">
				<h1 class="text-5xl md:text-7xl font-bold mb-6">
					<span class="gradient-text">Bitcoin</span>
					<br />
					<span class="text-white">The Future of Money</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed">
					Explore the world of cryptocurrencies, blockchain technology and 
					the decentralized financial revolution with expert analysis and quality content.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
					<a href="/blog" class="px-8 py-4 bg-bitcoin-orange text-white font-semibold rounded-lg hover:bg-bitcoin-light transition-all duration-300 transform hover:scale-105">
						Explore Blog
					</a>
					<a href="/about" class="px-8 py-4 border-2 border-bitcoin-orange text-bitcoin-orange font-semibold rounded-lg hover:bg-bitcoin-orange hover:text-white transition-all duration-300">
						Learn More
					</a>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
					<div class="bg-dark-card border border-dark-border rounded-lg p-6 card-hover">
						<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
							</svg>
						</div>
						<h2 class="text-xl font-semibold mb-2">Security</h2>
						<p class="text-gray-400">Advanced cryptographic technology that protects your transactions.</p>
					</div>
					
					<div class="bg-dark-card border border-dark-border rounded-lg p-6 card-hover">
						<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
							</svg>
						</div>
						<h2 class="text-xl font-semibold mb-2">Innovation</h2>
						<p class="text-gray-400">The most revolutionary technology of the 21st century.</p>
					</div>
					
					<div class="bg-dark-card border border-dark-border rounded-lg p-6 card-hover">
						<div class="w-12 h-12 bg-bitcoin-orange/20 rounded-lg flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-bitcoin-orange" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 16c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
							</svg>
						</div>
						<h2 class="text-xl font-semibold mb-2">Accessibility</h2>
						<p class="text-gray-400">Decentralized finance for everyone anywhere in the world.</p>
					</div>
				</div>
			</div>
		</div>
	</section>
	
	<section class="py-20 bg-dark-card">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<h2 class="text-4xl font-bold mb-4">
					<span class="gradient-text">Recent Articles</span>
				</h2>
				<p class="text-gray-400 text-lg">Stay informed with the latest news and analysis</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{latestPosts.map((post) => (
					<article class="bg-dark border border-dark-border rounded-lg overflow-hidden card-hover">
						<div class="h-48 bg-gradient-to-br from-bitcoin-orange/30 to-bitcoin-orange/10"></div>
						<div class="p-6">
							<div class="flex items-center space-x-2 text-sm text-gray-400 mb-3">
								<span>{formatDate(post.date)}</span>
								<span>•</span>
								<span>{post.readTime}</span>
							</div>
							<h3 class="text-xl font-semibold mb-3 hover:text-bitcoin-orange transition-colors">
								<a href={`/blog/${post.slug}`}>{post.title}</a>
							</h3>
							<p class="text-gray-400 mb-4">{post.description}</p>
							<a href={`/blog/${post.slug}`} class="text-bitcoin-orange hover:text-bitcoin-light transition-colors font-medium">
								Read More →
							</a>
						</div>
					</article>
				))}
			</div>
			
			<div class="text-center mt-12">
				<a href="/blog" class="px-8 py-3 border-2 border-bitcoin-orange text-bitcoin-orange font-semibold rounded-lg hover:bg-bitcoin-orange hover:text-white transition-all duration-300">
					View All Articles
				</a>
			</div>
		</div>
	</section>
	
	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-4xl font-bold mb-6">
					<span class="gradient-text">Join the Revolution</span>
				</h2>
				<p class="text-xl text-gray-300 mb-8">
					Bitcoin is not just a cryptocurrency, it's the future of decentralized finance. 
					Learn, invest and be part of the change.
				</p>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
					<div class="text-left">
						<h3 class="text-2xl font-semibold mb-4">Why Bitcoin?</h3>
						<ul class="space-y-3 text-gray-300">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Decentralized and without intermediaries</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Complete transparency on the blockchain</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Limited supply of 21 million</span>
							</li>
						</ul>
					</div>
					
					<div class="text-left">
						<h3 class="text-2xl font-semibold mb-4">Key Benefits</h3>
						<ul class="space-y-3 text-gray-300">
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Protection against inflation</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Global instant transfers</span>
							</li>
							<li class="flex items-start">
								<svg class="w-5 h-5 text-bitcoin-orange mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								<span>Complete control of your funds</span>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
