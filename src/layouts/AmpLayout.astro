---
export interface Props {
	title: string;
	description?: string;
	canonicalUrl: string;
}

const { title, description, canonicalUrl } = Astro.props;

const ampAttrs: Record<string, string> = { amp: '' };
---

<!doctype html>
<html lang="en" {...ampAttrs}>
	<head>
		<meta charset="utf-8" />
		<script async src="https://cdn.ampproject.org/v0.js"></script>
		<title>{title}</title>
		<link rel="canonical" href={canonicalUrl} />
		<meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1" />
		<style amp-boilerplate>
			body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}
			@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}
			@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}
			@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}
			@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}
			@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}
		</style>
		<noscript>
			<style amp-boilerplate>
				body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}
			</style>
		</noscript>
		{description && <meta name="description" content={description} />}
		<style amp-custom>
			body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;line-height:1.6;margin:0;padding:16px;color:#111;background:#fff}
			a{color:#f7931a}
			header{margin-bottom:16px}
			.container{max-width:900px;margin:0 auto}
			h1{font-size:28px;line-height:1.2;margin:0 0 8px}
			.nav a{margin-right:12px}
		</style>
	</head>
	<body>
		<div class="container">
			<header>
				<div class="nav">
					<a href="/">Home</a>
					<a href="/blog">Blog</a>
				</div>
			</header>
			<main>
				<slot />
			</main>
		</div>
	</body>
</html>
