---
import { SITE } from '../config.js';
import SimpleSEO from '../components/SimpleSEO.astro';
import '../styles/global.css';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	url?: string;
	type?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	category?: string;
	tags?: string[];
	keywords?: string;
	author?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { 
	title, 
	description = SITE.description, 
	image = SITE.image, 
	url = canonicalURL,
	type = 'website',
	publishedTime,
	modifiedTime,
	category,
	tags = [],
	keywords,
	author = SITE.author
} = Astro.props;

const pathname = Astro.url.pathname;
const ampUrl = (() => {
	if (pathname === '/') return new URL('/amp', Astro.site).href;
	if (pathname === '/blog') return new URL('/blog/amp', Astro.site).href;
	if (pathname.startsWith('/blog/') && !pathname.endsWith('/amp')) return new URL(`${pathname.replace(/\/$/, '')}/amp`, Astro.site).href;
	return undefined;
})();
---

<!DOCTYPE html>
<html lang="en">
<head>

<!-- Critical CSS for above-fold content -->

<!-- Resource hints for performance -->
<link rel="dns-prefetch" href="//fonts.googleapis.com">
<link rel="dns-prefetch" href="//www.googletagmanager.com">
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
