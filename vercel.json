{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/$1?",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bitcoinforwifi.com"
        }
      ],
      "destination": "https://www.bitcoinforwifi.com/$1?$query",
      "permanent": true
    }
  ]
}
