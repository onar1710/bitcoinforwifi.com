{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bitcoinforwifi.com"
        }
      ],
      "destination": "https://www.bitcoinforwifi.com/$1?$query",
      "permanent": true
    },
    {
      "source": "/amp",
      "has": [
        {
          "type": "query",
          "key": "amp",
          "value": ""
        }
      ],
      "destination": "/amp",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "amp",
          "value": ""
        }
      ],
      "destination": "/amp",
      "permanent": false
    },
    {
      "source": "/blog/amp",
      "has": [
        {
          "type": "query",
          "key": "amp",
          "value": ""
        }
      ],
      "destination": "/blog/amp",
      "permanent": false
    },
    {
      "source": "/blog",
      "has": [
        {
          "type": "query",
          "key": "amp",
          "value": ""
        }
      ],
      "destination": "/blog/amp",
      "permanent": false
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "query",
          "key": "amp",
          "value": ""
        }
      ],
      "destination": "/blog/:slug/amp",
      "permanent": false
    }
  ]
}
