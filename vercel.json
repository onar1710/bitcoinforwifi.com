{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/amp",
      "permanent": true
    },
    {
      "source": "/blog",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/blog/amp",
      "permanent": true
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/blog/:slug/amp",
      "permanent": true
    }
  ]
}
