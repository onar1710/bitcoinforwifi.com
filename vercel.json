{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/amp"
    },
    {
      "source": "/blog",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/blog/amp"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "query",
          "key": "amp"
        }
      ],
      "destination": "/blog/:slug/amp"
    }
  ]
}
